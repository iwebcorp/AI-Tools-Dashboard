{
  "name": "ai-auto",
  "displayName": "Ai auto",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "DU",
  "scripts": {
    "dev": "plasmo dev",
    "dev:detached": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev-detached.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev-detached.ps1",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.1.42",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "plasmo": "0.90.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "cookies",
      "tabs",
      "storage",
      "alarms"
    ],
    "host_permissions": [
      "https://*.cursor.com/*",
      "https://*.chatgpt.com/*",
      "http://localhost:3000/*",
      "https://ai-tools-dashboard-psi.vercel.app/*"
    ]
  }
}
